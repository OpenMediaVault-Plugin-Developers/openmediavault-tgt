msgid "Backing store"
msgstr "ແຫຼ່ງເກັບຂໍ້ມູນ"

msgid "Create"
msgstr "ສ້າງ"

msgid "Created image."
msgstr "ສ້າງອິເມຈແລ້ວ."

msgid "Created target."
msgstr "ສ້າງເປົ້າໝາຍແລ້ວ."

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Edit target."
msgstr "ແກ້ໄຂເປົ້າໝາຍ."

msgid "Enable"
msgstr "ເປີດໃຊ້ງານ"

msgid "Enabled"
msgstr "ເປີດໃຊ້ງານແລ້ວ"

msgid "Enter new size in gigabytes."
msgstr "ປ້ອນຂະໜາດໃໝ່ເປັນກິກາໄບ (GB)."

msgid "Extra options"
msgstr "ຕົວເລືອກເພີ່ມເຕີມ"

msgid "Grow"
msgstr "ຂະຫຍາຍ"

msgid "IQN"
msgstr "IQN"

msgid "Image size"
msgstr "ຂະໜາດອິເມຈ"

msgid "Image size in gigabytes"
msgstr "ຂະໜາດອິເມຈເປັນກິກາໄບ"

msgid "Images"
msgstr "ອິເມຈ"

msgid "Initiator address"
msgstr "ທີ່ຢູ່ຕົວເລີ່ມຕົ້ນ (Initiator)"

msgid ""
"Multiple addresses can be entered with a space between each entry.<br "
"/>Hostname or IP address can be used.<br />Field can be left blank to allow "
"any to access."
msgstr ""
"ສາມາດປ້ອນໄດ້ຫຼາຍທີ່ຢູ່ໂດຍການຍະຫວ່າງລະຫວ່າງແຕ່ລະລາຍການ.<br />ສາມາດໃຊ້ຊື່ໂຮສ "
"(Hostname) ຫຼື ທີ່ຢູ່ IP ໄດ້.<br "
"/>ສາມາດປະວ່າງໄວ້ເພື່ອອະນຸຍາດໃຫ້ທຸກຄົນເຂົ້າເຖິງໄດ້."

msgid ""
"Multiple backing stores can be entered with a comma between each entry."
msgstr "ສາມາດປ້ອນໄດ້ຫຼາຍແຫຼ່ງເກັບຂໍ້ມູນໂດຍໃຊ້ໝາຍຈຸດຂັ້ນລະຫວ່າງແຕ່ລະລາຍການ."

msgid "Name"
msgstr "ຊື່"

msgid "Only lowercase alphanumeric (a-z), dash (-), and dot (.) allowed!"
msgstr ""
"ອະນຸຍາດໃຫ້ໃຊ້ສະເພາະຕົວອັກສອນພາສາອັງກິດພິມນ້ອຍ (a-z), ເຄື່ອງໝາຍຂີດກາງ (-), "
"ແລະ ຈຸດ (.) ເທົ່ານັ້ນ!"

msgid "Path"
msgstr "ເສັ້ນທາງ"

msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

msgid "Size"
msgstr "ຂະໜາດ"

msgid "Targets"
msgstr "ເປົ້າໝາຍ (Targets)"

msgid "Tgt"
msgstr "Tgt"

msgid "iqn not set"
msgstr "ຍັງບໍ່ໄດ້ກຳນົດ iqn"

msgid "tgt"
msgstr "tgt"
